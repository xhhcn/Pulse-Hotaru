# Dependencies
node_modules/

# Build outputs
dist/
.astro/
coverage/

# Compiled binaries
# Server binaries are built locally during development / by CI and NOT
# committed to the repo (the CI workflow uploads them to GitHub Release
# artifacts instead — see .github/workflows/docker.yml).
server/probe-server
server/probe-server.exe
server/pulse-server-standalone
server/pulse-server-standalone-linux-amd64
server/pulse-server-standalone-linux-arm64
# NOTE: client/probe-client* binaries ARE intentionally committed to the
# repo for distribution (install.sh downloads them via raw.githubusercontent).
# The Build Client Binaries workflow regenerates them on every push to main
# and commits the updated artifacts. Do NOT add them here — if they were
# gitignored, CI would need `git add -f` and devs couldn't normally track
# local rebuilds.

# Database and data files
*.db
*.db-journal
data/
!server/web/src/data/
!server/web/src/data/*.ts

# IDE and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Environment files
.env
.env.local
.env.*.local

# Docker artifacts (keep Dockerfile and docker-compose)
.docker/

# Temporary files
tmp/
temp/
*.tmp

# Sensitive files - NEVER commit these
*recovery-codes*
*secret*
*password*
*.key
*.pem
*.p12
*.pfx
