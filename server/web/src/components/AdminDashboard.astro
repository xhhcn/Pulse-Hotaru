  async function loadPrivacyConfig() {
    try {
      const res = await fetch(`${apiBase}/api/privacy/config`);
      if (res.ok) {
        const config = await res.json();
        
        // Update privacy enabled checkbox
        if (privacyEnabledCheckbox) {
          privacyEnabledCheckbox.checked = config.enabled || false;
        }
        
        // Update expiration hours input with saved value (convert seconds to hours)
        if (tokenExpiresHoursInput) {
          const hours = Math.round((config.expires_in_seconds || 3600) / 3600);
          tokenExpiresHoursInput.value = hours;
        }
        
        // Update share section visibility
        if (shareSection) {
          shareSection.style.display = config.enabled ? 'block' : 'none';
        }
        
        // Update current share link if exists
        if (config.share_token && config.share_token !== '') {
          const shareUrl = `${window.location.origin}/?token=${config.share_token}`;
          if (currentShareLinkInput) {
            currentShareLinkInput.value = shareUrl;
          }
          if (currentShareLinkContainer) {
            currentShareLinkContainer.classList.remove('hidden');
          }
          if (tokenExpiresInfo && config.token_expires) {
            // Use server time if available, otherwise fall back to client time
            const serverTime = config.server_time ? new Date(config.server_time) : new Date();
            const expiresDate = new Date(config.token_expires);
            
            // Check if token is expired based on server time
            if (config.token_expired === true) {
              // Token is already expired according to server
              tokenExpiresInfo.textContent = 'Expired';
              tokenExpiresInfo.className = 'mt-1 text-xs text-red-500 dark:text-red-400';
            } else {
              // Calculate time difference using server time
              const timeDiff = expiresDate.getTime() - serverTime.getTime();
              if (timeDiff > 1000) {
                // Token is still valid (more than 1 second remaining)
                tokenExpiresInfo.textContent = `Expires: ${formatDate(config.token_expires)}`;
                tokenExpiresInfo.className = 'mt-1 text-xs text-[#525252] dark:text-[#737373]';
                
                // Set up a timer to update the status when it actually expires
                // Use the calculated time difference
                setTimeout(() => {
                  if (tokenExpiresInfo) {
                    tokenExpiresInfo.textContent = 'Expired';
                    tokenExpiresInfo.className = 'mt-1 text-xs text-red-500 dark:text-red-400';
                  }
                }, timeDiff);
              } else {
                // Token is expired or will expire within 1 second
                tokenExpiresInfo.textContent = 'Expired';
                tokenExpiresInfo.className = 'mt-1 text-xs text-red-500 dark:text-red-400';
              }
            }
          }
        } else {
          if (currentShareLinkContainer) {
            currentShareLinkContainer.classList.add('hidden');
          }
        }
      }
    } catch (err) {
