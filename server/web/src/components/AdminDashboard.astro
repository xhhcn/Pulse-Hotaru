  // Download Backup button — one-click consistent hot snapshot of the
  // bbolt database straight to the operator's Downloads folder. Zero
  // downtime on the server; the file is byte-for-byte identical to the
  // one scripts/backup.sh would fetch via the CLI, so it can be fed
  // straight to scripts/restore.sh or pulse-migrate on any new host.
  //
  // A plain <a href="/api/admin/backup"> won't work because the admin
  // token lives in localStorage (not a cookie), so we fetch with the
  // Authorization: Bearer header and synthesise a blob download.
  const backupBtn = document.getElementById('backup-btn');
  if (backupBtn) {
    backupBtn.addEventListener('click', async () => {
      const token = localStorage.getItem('admin_auth_token');
      if (!token) {
        window.location.href = '/login?redirect=/admin';
        return;
      }
      if (backupBtn.dataset.busy === '1') return;
      backupBtn.dataset.busy = '1';
      backupBtn.setAttribute('disabled', 'true');
      const iconEl = backupBtn.querySelector('svg');
      if (iconEl) iconEl.classList.add('animate-pulse');

      const pad = function (n) { return n < 10 ? '0' + n : '' + n; };
      const d = new Date();
      const tsFallback = d.getUTCFullYear()
        + pad(d.getUTCMonth() + 1) + pad(d.getUTCDate()) + 'T'
        + pad(d.getUTCHours()) + pad(d.getUTCMinutes()) + pad(d.getUTCSeconds()) + 'Z';
      let filename = 'pulse-backup-' + tsFallback + '.db';

      let errorMessage = '';
      try {
        const res = await fetch(apiBase + '/api/admin/backup', {
          method: 'GET',
          headers: { 'Authorization': 'Bearer ' + token },
        });
        if (res.status === 401) {
          localStorage.removeItem('admin_auth_token');
          window.location.href = '/login?redirect=/admin';
          return;
        }
        if (!res.ok) {
          throw new Error('HTTP ' + res.status);
        }
        const disp = res.headers.get('Content-Disposition') || '';
        const fnMatch = disp.match(/filename=([^;]+)/);
        if (fnMatch && fnMatch[1]) {
          filename = fnMatch[1].replace(/^"|"$/g, '').trim();
        }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(function () { URL.revokeObjectURL(url); }, 30000);
      } catch (err) {
        console.error('[backup]', err);
        errorMessage = (err && err.message) ? err.message : String(err);
      }

      backupBtn.removeAttribute('disabled');
      delete backupBtn.dataset.busy;
      if (iconEl) iconEl.classList.remove('animate-pulse');
      if (errorMessage) {
        const lang = (document.documentElement.getAttribute('lang') || 'en').indexOf('zh') === 0 ? 'zh' : 'en';
        const prefix = lang === 'zh' ? '下载备份失败：' : 'Failed to download backup: ';
        alert(prefix + errorMessage);
      }
    });
  }

