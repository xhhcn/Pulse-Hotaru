                  </svg>
                  <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                </button>
              </div>
            `;
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = ipv6RowHTML.trim();
            const newRow = tempDiv.firstElementChild;
            if (newRow && ipContainer) {
              ipContainer.appendChild(newRow);
            }
          } else if (nameAndIpContainerForIPv6) {
            // No container exists, need to create it
            const ipContainerHTML = `
              <div class="ip-info-container hidden sm:flex flex-col gap-1 text-xs min-h-[48px] flex-shrink-0 justify-center">
                <div class="flex items-center gap-1.5 min-h-[22px]">
                  <span class="text-[#404040] dark:text-[#a3a3a3] shrink-0">IPv6:</span>
                  <span class="system-ipv6 text-[#262626] dark:text-[#d4d4d4] font-mono text-xs">${escapeHtml(item.ipv6 || '')}</span>
                  <button class="copy-ip-btn shrink-0 rounded p-1 text-[#525252] dark:text-[#737373] hover:text-[#262626] dark:hover:text-[#d4d4d4] hover:bg-[#282828] dark:hover:bg-[#282828] hover:bg-[#f0f0f0] transition-colors" data-ip="${escapeHtmlAttr(item.ipv6 || '')}" title="Copy IPv6">
