  // Handle navbar config form submission
  navbarConfigForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(navbarConfigForm);
    const messageEl = document.getElementById('navbar-config-message');
    const submitBtn = navbarConfigForm.querySelector('button[type="submit"]');
    const sharedSecretInput = document.getElementById('navbar-shared-secret-input');
    const customCodeInput = document.getElementById('navbar-custom-code-input');
    
    // Parse custom code to separate CSS and JS
    const customCode = customCodeInput?.value || '';
    let customCSS = '';
    let customJS = '';
    
    // Extract <style> tags for CSS (only content)
    const styleMatches = customCode.matchAll(/<style[^>]*>([\s\S]*?)<\/style>/gi);
    for (const match of styleMatches) {
      customCSS += match[1] + '\n';
    }
    
    // Extract script tags for JS (preserve ALL complete tags for proper multi-script support)
    const scriptTag = 'script';
    const scriptRegex = new RegExp('<' + scriptTag + '([^>]*)>([\\s\\S]*?)<\\/' + scriptTag + '>', 'gi');
    const scriptMatches = customCode.matchAll(scriptRegex);
    for (const match of scriptMatches) {
      const attributes = match[1];
      const content = match[2];
      
      // IMPORTANT: Preserve complete <script> tags for ALL scripts (external and inline)
      // This ensures multiple scripts work correctly (e.g., library + usage code)
      if (attributes.includes('src=')) {
        // External script - preserve full tag
        customJS += match[0] + '\n';
      } else {
        // Inline script - wrap content back in <script> tags to maintain structure
        customJS += '<' + scriptTag + '>\n' + content + '\n</' + scriptTag + '>\n';
      }
    }
    
    // If no tags found, treat CSS (starting with /* or .) and JS (starting with //, function, var, let, const) separately
    if (!customCSS && !customJS) {
      const lines = customCode.split('\n');
      let currentBlock = '';
      let isCSS = false;
      
      for (const line of lines) {
        const trimmed = line.trim();
        if (trimmed.startsWith('/*') || trimmed.startsWith('.') || trimmed.startsWith('#') || trimmed.includes('{')) {
          isCSS = true;
        } else if (trimmed.startsWith('//') || trimmed.startsWith('function') || trimmed.startsWith('var ') || 
                   trimmed.startsWith('let ') || trimmed.startsWith('const ') || trimmed.startsWith('console.')) {
          isCSS = false;
        }
        
        if (isCSS) {
          customCSS += line + '\n';
        } else if (trimmed) {
          customJS += line + '\n';
        }
      }
    }
    
    const showTrafficToggle = document.getElementById('show-traffic-toggle');
    const showGlassToggle = document.getElementById('show-glass-toggle');
    const data = {
      text: formData.get('text')?.trim() || 'Pulse',
      logo: formData.get('logo')?.trim() || '',
      shared_secret: sharedSecretInput?.value || '',
      custom_css: customCSS.trim(),
      custom_js: customJS.trim(),
      show_traffic: showTrafficToggle?.checked || false,
      show_glass: showGlassToggle?.checked || false,
    };

    // Set button to saving state
    if (submitBtn) {
      submitBtn.disabled = true;
      const saveSpan = submitBtn.querySelector('span');
      if (saveSpan) {
        saveSpan.textContent = 'Saving...';
      } else {
        submitBtn.textContent = 'Saving...';
      }
    }

    try {
      const res = await fetch(`${apiBase}/api/navbar/config`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        // Close modal immediately on success and reload
        closeNavbarConfigModal();
        // Reload page to apply navbar changes
        window.location.reload();
      } else {
        const error = await res.text();
        throw new Error(error || `HTTP ${res.status}`);
      }
    } catch (err) {
      // Reset button state on error
      if (submitBtn) {
        submitBtn.disabled = false;
        const saveSpan = submitBtn.querySelector('span');
        if (saveSpan) {
          saveSpan.textContent = 'Save';
        } else {
          submitBtn.textContent = 'Save';
        }
      }
      if (messageEl) {
        messageEl.className = 'text-sm text-red-500 dark:text-red-400';
        messageEl.textContent = '❌ Failed to save navbar config: ' + err.message;
        messageEl.classList.remove('hidden');
      }
    }
  });

  // Add target button
  addTargetBtn?.addEventListener('click', () => {
    if (targetsContainer) {
      targetsContainer.appendChild(createTargetInput());
    }
  });

  // Form submission
  tcpingConfigForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const intervalInput = document.getElementById('tcping-interval');
    const interval = parseInt(intervalInput?.value || '60');
    
    // Collect all target values (name and address pairs)
    const targetRows = targetsContainer?.querySelectorAll('.target-row') || [];
    const targets = [];
    
    for (const row of targetRows) {
      const nameInput = row.querySelector('.target-name-input');
      const addressInput = row.querySelector('.target-address-input');
      
      if (nameInput && addressInput) {
        const name = nameInput.value.trim();
        const address = addressInput.value.trim();
        
        if (name && address) {
          targets.push({ name, address });
        } else if (address) {
          // If only address is provided, use address as name
          targets.push({ name: address, address });
        }
      }
    }
    
    // Allow empty targets list (default state - tcping disabled)
    // No validation needed for empty targets
    
    const config = {
      targets: targets,
      interval_secs: interval
    };
    
    const submitBtn = tcpingConfigForm.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';
    }
    
    try {
      const res = await fetch(`${apiBase}/api/tcping/config`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(config),
      });
      
      if (res.ok) {
        // Close modal immediately on success
        closeTCPingConfigModal();
      } else {
        const messageEl = document.getElementById('tcping-config-message');
        const error = await res.text();
        if (messageEl) {
          messageEl.textContent = `Failed to save: ${error}`;
          messageEl.className = 'text-sm text-red-500 dark:text-red-400';
          messageEl.classList.remove('hidden');
        }
      }
    } catch (err) {
      const messageEl = document.getElementById('tcping-config-message');
      if (messageEl) {
        messageEl.textContent = `Error: ${err.message}`;
        messageEl.className = 'text-sm text-red-500 dark:text-red-400';
        messageEl.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save';
      }
    }
  });

  // Debounce loadSystems to prevent duplicate updates (kept for legacy paths
  // that fetch before rendering — SSE metric_updated now skips this entirely).
  let loadSystemsTimeout = null;
  const debouncedLoadSystems = () => {
    if (loadSystemsTimeout) {
      clearTimeout(loadSystemsTimeout);
    }
    loadSystemsTimeout = setTimeout(() => {
      loadSystems();
      loadSystemsTimeout = null;
    }, 100); // 100ms debounce - prevents rapid consecutive calls
  };

  // Single self-serialised render path for the admin table.
  //
  // Multiple callers can request a render concurrently (SSE push, user
  // actions, refresh button, admin mutation responses). To keep DOM updates
  // atomic we wrap renderSystems with an in-flight flag and a latest-wins
  // "pending" slot. If a new render is requested while one is running, its
  // data is held and processed immediately after the current render ends,
  // with any intermediate payloads dropped. This guarantees two concurrent
  // callers never interleave DOM mutations and the freshest data always wins.
  let isRenderSystemsRunning = false;
  let pendingSystemsData = null;
  async function renderSystemsSerialized(data) {
    if (!Array.isArray(data)) return;
    if (isRenderSystemsRunning) {
      pendingSystemsData = data;
      return;
    }
    isRenderSystemsRunning = true;
    try {
      let current = data;
      while (current) {
        try {
          await renderSystems(current);
        } catch (err) {
          console.error('renderSystems failed:', err);
        }
        current = pendingSystemsData;
        pendingSystemsData = null;
      }
    } finally {
      isRenderSystemsRunning = false;
    }
  }

  // debouncedRenderSystems is an 80 ms coalescer for rapid SSE events, on top
  // of the serialiser above. The coalesce is purely a CPU optimisation — the
  // serialiser would already give the right correctness properties alone.
  let renderSystemsTimeout = null;
  const debouncedRenderSystems = (data) => {
    pendingSystemsData = data;
    if (renderSystemsTimeout) return;
    renderSystemsTimeout = setTimeout(() => {
      renderSystemsTimeout = null;
      const d = pendingSystemsData;
      pendingSystemsData = null;
      if (d) renderSystemsSerialized(d);
    }, 80);
  };

  // Connect to SSE for real-time updates from other clients or agents.
  //
  // Same reliability strategy as the public dashboard:
  //   * Exponential backoff with jitter on reconnect (no thundering herd).
  //   * 45 s liveness watchdog: server emits either an update event (~3 s) or
  //     a keepalive comment (~15 s), so 45 s of silence means the TCP stream
  //     is half-open and we should reconnect proactively.
  let sseReconnectAttempt = 0;
  let sseWatchdogTimer = null;
  const SSE_WATCHDOG_MS = 45_000;

  function markSSEAlive() {
    if (sseWatchdogTimer) {
      clearTimeout(sseWatchdogTimer);
    }
    sseWatchdogTimer = setTimeout(() => {
      if (eventSource) {
        try { eventSource.close(); } catch (_) {}
        eventSource = null;
      }
      scheduleSSEReconnect();
    }, SSE_WATCHDOG_MS);
  }

  function scheduleSSEReconnect() {
    const base = Math.min(30_000, 1000 * Math.pow(2, sseReconnectAttempt));
    const jitter = Math.floor(Math.random() * 1000);
    sseReconnectAttempt++;
    setTimeout(connectSSE, base + jitter);
  }

  function connectSSE() {
    if (eventSource) {
      eventSource.close();
    }
    if (sseWatchdogTimer) {
      clearTimeout(sseWatchdogTimer);
      sseWatchdogTimer = null;
    }

    // CRITICAL: pass the admin token via the `admin_token` query parameter
    // so the server subscribes us with the SSEViewAdmin view.
    //
    // EventSource does NOT support custom request headers, so we cannot send
    // the admin token via `Authorization: Bearer` like we do for other API
    // calls — the only way to identify ourselves at SSE time is the URL.
    //
    // Without this query parameter, the server would treat us as a public
    // subscriber and broadcast the masked snapshot (Secret / IPv4 / IPv6
    // stripped). That makes the admin page's "copy secret" button show an
    // empty value, and IP / agent fields appear blank. With the token
    // included, the server tags our subscription as admin and every
    // metric_updated push contains the full, authoritative row.
    const adminToken = localStorage.getItem('admin_auth_token');
    let sseUrl = `${apiBase}/api/events`;
    if (adminToken) {
      sseUrl += `?admin_token=${encodeURIComponent(adminToken)}`;
    }
    eventSource = new EventSource(sseUrl);
    markSSEAlive();

    eventSource.addEventListener('connected', (e) => {
      // (Re)connected — reset backoff so a future independent disconnect
      // starts over at 1 s.
      sseReconnectAttempt = 0;
      markSSEAlive();
    });

    // onmessage fires for untyped messages AND keeps the watchdog happy for
    // any server traffic; typed events have their own listeners below.
    eventSource.onmessage = () => {
      markSSEAlive();
    };

    // Backend-push model:
    //   * metric_updated embeds the full systems list in `update.systems`.
    //     Render directly from it — do NOT issue GET /api/metrics.
    //   * metric_deleted is signal-only; fall back to a fetch so the
    //     deletion propagates even if the paired metric_updated was
    //     dropped by a slow middlebox.
    //   * order updates are handled locally by drag & drop, so we ignore
    //     order_updated here.
    eventSource.addEventListener('update', (e) => {
      markSSEAlive();
      let update;
      try {
        update = JSON.parse(e.data);
      } catch (_) {
        return;
      }

      if (update.type === 'metric_updated') {
        if (Array.isArray(update.systems)) {
          debouncedRenderSystems(update.systems);
        } else {
          debouncedLoadSystems();
        }
      } else if (update.type === 'metric_deleted') {
        debouncedLoadSystems();
      }
    });

    eventSource.onerror = (err) => {
      if (eventSource) {
        eventSource.close();
        eventSource = null;
      }
      if (sseWatchdogTimer) {
        clearTimeout(sseWatchdogTimer);
        sseWatchdogTimer = null;
      }
      scheduleSSEReconnect();
    };
  }

  // Initial bootstrap: SSE is the primary data source (server pushes an
  // authoritative snapshot on connect and again on every admin mutation).
  // The browser does NOT poll. A one-shot GET is issued only as a safety
  // net if SSE hasn't delivered any data within a short grace window, so
  // the admin UI is never stuck on "loading".
  connectSSE();
  setTimeout(() => {
    if (!initialSystemsRendered) {
      loadSystems();
    }
  }, 2500);

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    // Stop auto-scroll if active
    stopAutoScroll();
    
    // Close SSE connection
    if (eventSource) {
      eventSource.close();
      eventSource = null;
    }
    
    // Clean up dragged element state
    draggedElement = null;
    draggedIndex = null;
  });

  // Translation functionality for AdminDashboard
  const adminTranslations = {
    'systemList': { en: 'Service List', zh: '服务列表' },
    'addSystem': { en: 'Add Service', zh: '添加服务' },
    'refresh': { en: 'Refresh', zh: '刷新' },
    'tcpingSettings': { en: 'TCPing Settings', zh: 'TCPing 设置' },
    'pollingInterval': { en: 'Polling Interval', zh: '轮询间隔' },
    'seconds': { en: 'seconds', zh: '秒' },
    'pollingIntervalDesc': { en: 'How often to send tcping requests to clients', zh: '向客户端发送 tcping 请求的频率' },
    'tcpingTargets': { en: 'TCPing Targets', zh: 'TCPing 目标' },
    'addTarget': { en: '+ Add Target', zh: '+ 添加目标' },
    'targetFormatDesc': { en: 'Format: name and address (e.g., Google DNS, 8.8.8.8:53)', zh: '格式：名称和地址（例如：Google DNS, 8.8.8.8:53）' },
    'targetName': { en: 'Target Name', zh: '目标名称' },
    'save': { en: 'Save', zh: '保存' },
    'loadingSystems': { en: 'Loading services...', zh: '加载服务中...' },
    'addNewSystem': { en: 'Add New Service', zh: '添加新服务' },
    'editSystem': { en: 'Edit Service', zh: '编辑服务' },
    'deleteSystem': { en: 'Delete Service', zh: '删除服务' },
    'systemName': { en: 'Service Name', zh: '服务名称' },
    'displayNameForThisSystem': { en: 'Display name for this system', zh: '此服务的显示名称' },
    'myServer': { en: 'My Server', zh: '我的服务器' },
    'tags': { en: 'Tags', zh: '标签' },
    'tagsCommaSeparated': { en: '(comma-separated)', zh: '（逗号分隔）' },
    'tagsHint': { en: 'Enter tags separated by commas (e.g., Python, traffic:in, speed:in, spr:VIP, spy:staff, spb:pro). Prefix with spr:/spy:/spb: for a red/amber/blue gradient badge.', zh: '输入标签，用逗号分隔（例如：Python, traffic:in, speed:in, spr:VIP, spy:staff, spb:pro）。前缀 spr:/spy:/spb: 分别表示红色 / 金色 / 蓝色起始的渐变彩色徽章。' },
    'cancel': { en: 'Cancel', zh: '取消' },
    'updateSystem': { en: 'Update System', zh: '更新服务' },
    'areYouSureYouWantToDelete': { en: 'Are you sure you want to delete', zh: '您确定要删除' },
    'thisActionCannotBeUndone': { en: 'This action cannot be undone.', zh: '此操作无法撤销。' },
    'delete': { en: 'Delete', zh: '删除' },
    'remove': { en: 'Remove', zh: '移除' },
    'note': { en: 'Note:', zh: '注意:' },
    'noteContent': { en: 'IP addresses, location, OS and metrics are automatically updated by the agent and cannot be edited manually.', zh: 'IP 地址、位置、操作系统和指标由代理自动更新，无法手动编辑。' },
    'changePassword': { en: 'Change Password', zh: '修改密码' },
    'currentPassword': { en: 'Current Password', zh: '当前密码' },
    'newPassword': { en: 'New Password', zh: '新密码' },
    'confirmNewPassword': { en: 'Confirm New Password', zh: '确认新密码' },
    'passwordMinLength': { en: 'Password must be at least 6 characters long', zh: '密码长度至少为6个字符' },
    'customizationSettings': { en: 'Customization Settings', zh: '自定义设置' },
    'navbarText': { en: 'Navbar Text', zh: '导航栏文字' },
    'navbarLogo': { en: 'Navbar Logo', zh: '导航栏图标' },
    'navbarTextHint': { en: 'Custom text displayed in navbar (leave empty for default: Pulse)', zh: '导航栏显示的自定义文字（留空使用默认：Pulse）' },
    'navbarLogoHint': { en: 'Logo URL or SVG code (leave empty for default logo)', zh: '图标URL或SVG代码（留空使用默认图标）' },
    'sharedSecret': { en: 'Shared Secret', zh: '共享密钥' },
    'sharedSecretHint': { en: 'This secret is shared by all clients for authentication', zh: '所有客户端共享此密钥进行认证' },
    'regenerate': { en: 'Regenerate', zh: '重新生成' },
    'confirmRegenerateTitle': { en: 'Regenerate Shared Secret?', zh: '重新生成共享密钥？' },
    'confirmRegenerateMessage': { en: 'All existing clients will need to be reconfigured with the new secret!', zh: '所有现有客户端将需要使用新的密钥重新配置！' },
    'warning': { en: 'Warning', zh: '警告' },
    'privacySettings': { en: 'Privacy Settings', zh: '隐私设置' },
    'enablePrivacyMode': { en: 'Enable Privacy Mode', zh: '启用隐私模式' },
    'privacyModeDesc': { en: 'When enabled, login page will appear before index page. Admin page does not require login.', zh: '启用后，登录页将出现在首页之前。管理页面无需登录。' },
    'temporaryShare': { en: 'Temporary Share', zh: '临时分享' },
    'temporaryShareDesc': { en: 'Generate a temporary share link that allows access without login. Login page will appear before admin page for share links.', zh: '生成临时分享链接，允许无需登录访问。分享链接的登录页将出现在管理页面之前。' },
    'currentShareLink': { en: 'Current Share Link', zh: '当前分享链接' },
    'expirationHours': { en: 'Expiration (Hours)', zh: '有效期（小时）' },
    'expirationHoursHint': { en: 'Number of hours until the share link expires (1-720, max 30 days)', zh: '分享链接过期前的小时数（1-720，最多30天）' },
    'generateShareLink': { en: 'Generate Share Link', zh: '生成分享链接' },
    'revokeShareLink': { en: 'Revoke Share Link', zh: '立即停止分享链接' },
    'copy': { en: 'Copy', zh: '复制' },
    'customCodeHint': { en: 'Custom CSS and JavaScript will be applied to all pages. Use <style> for CSS or <script> for JS', zh: '自定义 CSS 和 JavaScript 将应用于所有页面。使用 <style> 标签添加 CSS，使用 <script> 标签添加 JS' },
    'customCodeSecurityWarning': { en: '⚠️ Security Warning: Do NOT include sensitive information (API keys, passwords, tokens).', zh: '⚠️ 安全提示：请勿包含敏感信息（API密钥、密码、令牌等）' },
    'showTrafficLabel': { en: 'Show Traffic Info', zh: '显示流量信息' },
    'showTrafficDesc': { en: 'Display real-time and total traffic in the detail dropdown section', zh: '在下拉详情部分显示实时流量和总流量' },
    'showGlassLabel': { en: 'Glassmorphism Effect', zh: '毛玻璃特效' },
    'showGlassDesc': { en: 'Enable frosted glass visual effect on navbar and cards', zh: '为导航栏和卡片启用毛玻璃视觉效果' },
  };

  function updateAdminTranslations() {
    const lang = localStorage.getItem('preferred-language') || 'en';
    
    // Update all elements with data-translate attribute
    document.querySelectorAll('[data-translate]').forEach(el => {
      const key = el.getAttribute('data-translate');
      if (key && adminTranslations[key]) {
        el.textContent = adminTranslations[key][lang];
      }
    });

    // Update title attributes. We also mirror the value onto aria-label so
    // that screen-reader users hear the same localized description that
    // sighted users see in the tooltip — these icon-only buttons have no
    // visible text label to announce otherwise. The HTML ships with an
    // English default for both attributes, so tooltips/ARIA remain usable
    // even if this JS hasn't run yet (or failed to run due to an error
    // earlier on the page).
    document.querySelectorAll('[data-title-en]').forEach(el => {
      const enTitle = el.getAttribute('data-title-en');
      const zhTitle = el.getAttribute('data-title-zh');
      if (enTitle && zhTitle) {
        const value = lang === 'zh' ? zhTitle : enTitle;
        el.setAttribute('title', value);
        // Only sync aria-label if the element declared one in the source
        // markup — we don't want to silently add ARIA names to elements
        // that intentionally omitted them (e.g. labelled via nearby text).
        if (el.hasAttribute('aria-label')) {
          el.setAttribute('aria-label', value);
        }
      }
    });

    // Update placeholder attributes
    document.querySelectorAll('[data-placeholder-en]').forEach(el => {
      const enPlaceholder = el.getAttribute('data-placeholder-en');
      const zhPlaceholder = el.getAttribute('data-placeholder-zh');
      if (enPlaceholder && zhPlaceholder) {
        el.setAttribute('placeholder', lang === 'zh' ? zhPlaceholder : enPlaceholder);
      }
    });
  }

  // Listen for language changes
  window.addEventListener('languagechange', updateAdminTranslations);
  window.addEventListener('translate', updateAdminTranslations);

  // Initial translation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateAdminTranslations);
  } else {
    updateAdminTranslations();
  }
</script>
