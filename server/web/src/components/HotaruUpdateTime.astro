---
/**
 * HotaruUpdateTime.astro
 *
 * Tiny status line shown between the table and the card grid that
 * reports how long ago the last successful /api/metrics tick was.
 * Listens on `pulse:metrics-tick` (broadcast by HotaruServerTable)
 * and re-renders once per second using a relative-time formatter.
 */
---

<div class="hotaru-updated" id="hotaru-updated">最后更新: 从未.</div>

<script is:inline>
  (function () {
    const el = document.getElementById('hotaru-updated');
    if (!el) return;

    /* Hotaru's update-time line is hardcoded Chinese with the
       trailing "." style: 最后更新: 几秒前. / X 分钟前. / X 小时前.
       / X 日前. / X 月前. / X 年前. — we replicate that exact
       phrasing including the period.                              */
    let lastAt = 0;

    function fmt(s) {
      if (!s) return '从未.';
      const seconds = Math.floor((Date.now() - s) / 1000);
      let interval = Math.floor(seconds / 31536000);
      if (interval > 1) return interval + ' 年前.';
      interval = Math.floor(seconds / 2592000);
      if (interval > 1) return interval + ' 月前.';
      interval = Math.floor(seconds / 86400);
      if (interval > 1) return interval + ' 日前.';
      interval = Math.floor(seconds / 3600);
      if (interval > 1) return interval + ' 小时前.';
      interval = Math.floor(seconds / 60);
      if (interval > 1) return interval + ' 分钟前.';
      return '几秒前.';
    }
    function paint() {
      el.textContent = '最后更新: ' + fmt(lastAt);
    }
    paint();
    setInterval(paint, 1000);
    window.addEventListener('pulse:metrics-tick', (e) => {
      lastAt = (e && e.detail && e.detail.at) || Date.now();
      paint();
    });
  })();
</script>
