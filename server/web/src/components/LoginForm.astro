---
// Login form — light-mode only, Chinese only, no navbar.
// Visual language matches the hotaru cards (translucent white, soft
// drop shadow, rounded). All copy is hardcoded zh-CN.
---

<div class="hotaru-login-shell">
  <div class="hotaru-login-card" id="login-card">
    <div class="hotaru-login-header">
      <h1 id="login-title" class="hotaru-login-title">管理员登录</h1>
      <p id="login-subtitle" class="hotaru-login-subtitle">请输入密码以访问管理面板</p>
    </div>

    <div id="login-error" class="hotaru-login-alert hotaru-login-alert--error" hidden>
      <p id="login-error-text"></p>
    </div>
    <div id="login-success" class="hotaru-login-alert hotaru-login-alert--ok" hidden>
      <p id="login-success-text"></p>
    </div>

    <form id="login-form" class="hotaru-login-form" novalidate>
      <div class="hotaru-login-field">
        <label for="password">密码</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          autocomplete="current-password"
          placeholder="请输入密码"
        />
      </div>

      <div id="password-confirm-field" class="hotaru-login-field" hidden>
        <label for="password-confirm">确认密码</label>
        <input
          type="password"
          id="password-confirm"
          name="password_confirm"
          autocomplete="new-password"
          placeholder="请再次输入密码"
        />
      </div>

      <button type="submit" id="login-submit" class="hotaru-login-button">登录</button>
    </form>
  </div>
</div>

<script>
  function getApiBase() {
    const root = document.documentElement;
    if (root?.dataset?.apiBase && root.dataset.apiBase.trim() !== '') {
      return root.dataset.apiBase.trim();
    }
    return window.location.origin;
  }

  const apiBase = getApiBase();

  /* All login copy is hardcoded zh-CN — no language switch on this page. */
  const T = {
    titleLogin:        '管理员登录',
    titleSetup:        '设置管理员密码',
    subtitleLogin:     '请输入密码以访问管理面板',
    subtitleSetup:     '首次使用，请设置一个管理员密码',
    submitLogin:       '登录',
    submitSetup:       '设置密码',
    invalidPassword:   '密码错误',
    passwordTooShort:  '密码长度至少为 6 个字符',
    passwordMismatch:  '两次输入的密码不一致',
    setupSuccess:      '密码设置成功，正在跳转…',
    loginSuccess:      '登录成功，正在跳转…',
    networkError:      '网络错误，请重试',
    genericError:      '操作失败，请重试',
  };

  /* SECURITY: only allow a relative path (no protocol-relative, no
     absolute URLs, no parent-traversal). The redirect query param is
     attacker-controllable, and otherwise allows phishing redirects.   */
  function validateRedirect(redirect) {
    if (!redirect || typeof redirect !== 'string') return '/admin';
    redirect = redirect.trim();
    if (!redirect.startsWith('/')) return '/admin';
    if (redirect.startsWith('//')) return '/admin';
    if (redirect.includes(':')) return '/admin';
    if (redirect.includes('..')) return '/admin';
    return redirect;
  }

  async function checkPasswordStatus() {
    try {
      const res = await fetch(`${apiBase}/api/auth/status`, { cache: 'no-store' });
      if (res.ok) {
        const data = await res.json();
        return !!data.set;
      }
      /* Status endpoint unavailable / non-200:
         fail closed into login mode (single input) so we don't
         accidentally show "first-time setup" on an initialized site. */
      return null;
    } catch (_) {}
    return null;
  }

  async function setupPassword(password) {
    try {
      const res = await fetch(`${apiBase}/api/auth/setup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      if (!res.ok) {
        const errorText = await res.text();
        return { success: false, error: errorText || T.genericError };
      }
      return { success: true };
    } catch (err) {
      return { success: false, error: T.networkError };
    }
  }

  async function login(password) {
    try {
      const res = await fetch(`${apiBase}/api/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      if (res.ok) {
        const data = await res.json();
        if (data.success) {
          localStorage.setItem('admin_auth_token', data.token);
          return true;
        }
      }
      return false;
    } catch (_) {
      return false;
    }
  }

  function showAlert(kind, message) {
    const errEl = document.getElementById('login-error');
    const errTxt = document.getElementById('login-error-text');
    const okEl = document.getElementById('login-success');
    const okTxt = document.getElementById('login-success-text');

    if (kind === 'error') {
      errTxt.textContent = message;
      errEl.removeAttribute('hidden');
      okEl.setAttribute('hidden', '');
      window.clearTimeout(showAlert._t);
      showAlert._t = window.setTimeout(() => errEl.setAttribute('hidden', ''), 5000);
    } else {
      okTxt.textContent = message;
      okEl.removeAttribute('hidden');
      errEl.setAttribute('hidden', '');
    }
  }

  (async () => {
    const status = await checkPasswordStatus();
    let isSetupMode = (status === false);

    const titleEl    = document.getElementById('login-title');
    const subtitleEl = document.getElementById('login-subtitle');
    const submitBtn  = document.getElementById('login-submit');
    const form       = document.getElementById('login-form');
    const passwordEl = document.getElementById('password');
    const confirmFieldEl = document.getElementById('password-confirm-field');
    const confirmEl = document.getElementById('password-confirm');

    function applyMode() {
      if (isSetupMode) {
        titleEl.textContent    = T.titleSetup;
        subtitleEl.textContent = T.subtitleSetup;
        submitBtn.textContent  = T.submitSetup;
        if (confirmFieldEl) confirmFieldEl.removeAttribute('hidden');
        if (confirmEl) confirmEl.required = true;
        if (passwordEl) passwordEl.autocomplete = 'new-password';
      } else {
        titleEl.textContent    = T.titleLogin;
        subtitleEl.textContent = T.subtitleLogin;
        submitBtn.textContent  = T.submitLogin;
        if (confirmFieldEl) confirmFieldEl.setAttribute('hidden', '');
        if (confirmEl) confirmEl.required = false;
        if (confirmEl) confirmEl.value = '';
        if (passwordEl) passwordEl.autocomplete = 'current-password';
      }
    }
    applyMode();

    let inFlight = false;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (inFlight) return;

      const password = passwordEl.value.trim();

      if (password.length < 6) {
        showAlert('error', T.passwordTooShort);
        return;
      }

      if (isSetupMode) {
        const confirmPassword = (confirmEl?.value || '').trim();
        if (password !== confirmPassword) {
          showAlert('error', T.passwordMismatch);
          return;
        }
      }

      inFlight = true;
      submitBtn.disabled = true;
      submitBtn.classList.add('is-loading');

      try {
        if (isSetupMode) {
          const setup = await setupPassword(password);
          if (setup && setup.success) {
            showAlert('ok', T.setupSuccess);
            await login(password);
            const params = new URLSearchParams(window.location.search);
            window.location.href = validateRedirect(params.get('redirect') || '/admin');
          } else {
            const msg = (setup && setup.error) || T.genericError;
            if (/password already set/i.test(msg)) {
              // Status endpoint can be stale in some deployments/cache layers.
              // Fall back to login mode immediately instead of forcing 2 fields.
              isSetupMode = false;
              applyMode();
              const ok = await login(password);
              if (ok) {
                showAlert('ok', T.loginSuccess);
                const params = new URLSearchParams(window.location.search);
                window.location.href = validateRedirect(params.get('redirect') || '/admin');
              } else {
                showAlert('error', T.invalidPassword);
              }
            } else {
              showAlert('error', msg);
            }
          }
        } else {
          const ok = await login(password);
          if (ok) {
            showAlert('ok', T.loginSuccess);
            const params = new URLSearchParams(window.location.search);
            window.location.href = validateRedirect(params.get('redirect') || '/admin');
          } else {
            showAlert('error', T.invalidPassword);
          }
        }
      } finally {
        inFlight = false;
        submitBtn.disabled = false;
        submitBtn.classList.remove('is-loading');
      }
    });
  })();
</script>
