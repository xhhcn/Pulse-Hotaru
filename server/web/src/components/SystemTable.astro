  // Pre-calculate server name column width from data (before rendering DOM)
  // This prevents visual jitter by setting the correct width from the start
  function calculateServerNameColumnWidth(items) {
    if (!items || items.length === 0) return 100;
    
    let maxWidth = 100; // Minimum width in pixels (reduced for better mobile experience)
    
    // Create a temporary hidden span to measure text width accurately
    const tempSpan = document.createElement('span');
    // Match the global body font stack (global.css line 12) so measurements
    // reflect what Inter actually renders. Using a generic sans-serif here
    // would cause the measurement to silently drift from the real row width
    // (different glyph metrics → first column too wide or too narrow → the
    // very column-jitter we went to great lengths to eliminate).
    tempSpan.style.cssText = `
      position: absolute;
      visibility: hidden;
      white-space: nowrap;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: normal;
    `;
    // Add responsive font size calculation (text-[10px] sm:text-xs)
    const isSmallScreen = window.innerWidth < 640;
    if (isSmallScreen) {
      tempSpan.style.fontSize = '10px';
    }
    
    document.body.appendChild(tempSpan);
    
    // Measure each server name
    items.forEach(item => {
      const name = item.name || 'unknown';
      tempSpan.textContent = name;
      const textWidth = tempSpan.offsetWidth;
      
      // Add space for UI elements and ensure complete text display:
      // - Status dot: ~8px (w-1.5 sm:w-2)
      // - Gap after dot: 6px (gap-1.5)
      // - Gap before button: 6px (gap-1.5)
      // - Copy button: ~14px (w-2.5 sm:w-3)
      // - Extra buffer for font rendering variations: ~16px
      const uiElementsWidth = isSmallScreen ? 44 : 50; // Mobile: 44px, Desktop: 50px
      const estimatedCellWidth = textWidth + uiElementsWidth;
      maxWidth = Math.max(maxWidth, estimatedCellWidth);
    });
    
    document.body.removeChild(tempSpan);
    
    // Return the calculated width based on longest name
    // Table container has overflow-x-auto for horizontal scrolling on mobile if needed
    return Math.ceil(maxWidth);
  }
  
  // Apply the pre-calculated column width to all rows and header
  function applyServerNameColumnWidth(columnWidth) {
    // Update CSS variable at root level - this automatically affects all elements using var(--first-col-width)
    // Including: header row, loading skeleton rows, and all data rows
    const root = document.getElementById('monitor-root');
    if (root) {
      // CRITICAL: Only increase width, never decrease
      // This prevents LoadingState from being too narrow during SSE updates
      // When adding a system with a longer name, the LoadingState will expand correctly
      const currentWidthStr = root.style.getPropertyValue('--first-col-width');
      const currentWidth = parseInt(currentWidthStr) || 160;
      
      // Use the larger of current width or new calculated width
      const newWidth = Math.max(currentWidth, columnWidth);
      
      root.style.setProperty('--first-col-width', `${newWidth}px`);
      
      // CRITICAL: Force browser to immediately recalculate styles (trigger reflow)
      // Reading offsetHeight forces a synchronous layout recalculation
      // This ensures the CSS variable change is applied immediately
      void root.offsetHeight;
    }
  }
  
  // Recalculate column width from current data (used for incremental updates)
  function recalculateColumnWidthFromCurrentData() {
    if (currentData.size === 0) return;
    const items = Array.from(currentData.values());
    const width = calculateServerNameColumnWidth(items);
    applyServerNameColumnWidth(width);
  }

