  // SECURITY: HTML escape function to prevent XSS attacks
  function escapeHtml(text) {
    if (text == null) return '';
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    };
    return String(text).replace(/[&<>"']/g, m => map[m]);
  }

  // Format total traffic bytes to appropriate unit
  function formatTotalTraffic(bytes) {
    if (bytes === 0 || bytes == null) return '0 B';
    
    if (bytes < 1024) {
      return `${bytes} B`;
    } else if (bytes < 1024 * 1024) {
      return `${(bytes / 1024).toFixed(2)} KB`;
    } else if (bytes < 1024 * 1024 * 1024) {
      return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
    } else if (bytes < 1024 * 1024 * 1024 * 1024) {
      return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
    } else {
      return `${(bytes / (1024 * 1024 * 1024 * 1024)).toFixed(2)} TB`;
    }
  }

  // Format traffic speed from MB/s to appropriate unit
  function formatTrafficSpeed(mbps) {
    if (mbps === 0 || mbps == null) return '0 B/s';
    
    const bytes = mbps * 1024 * 1024; // Convert MB/s to Bytes/s
    
    if (bytes < 1024) {
      return `${bytes.toFixed(0)} B/s`;
    } else if (bytes < 1024 * 1024) {
      return `${(bytes / 1024).toFixed(1)} KB/s`;
    } else if (bytes < 1024 * 1024 * 1024) {
      return `${(bytes / (1024 * 1024)).toFixed(2)} MB/s`;
    } else {
      return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB/s`;
    }
  }

  // SECURITY: HTML attribute escape function
  function escapeHtmlAttr(text) {
    if (text == null) return '';
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    };
    return String(text).replace(/[&<>"']/g, m => map[m]);
  }

  // Backgrounds used by "spr:<label>" / "spy:<label>" / "spb:<label>" tags.
  //
  // Three user-selectable gradient families, one per prefix. The `sp*`
  // namespace marks all three as "special coloured badges"; the final
  // letter (r/y/b) picks which of the three pre-tuned gradient families
  // paints the badge, letting the operator emphasize a tag as warm /
  // neutral / cool without changing the label wording.
  //
  // Why a 3-letter `sp*` namespace rather than bare `r:` / `y:` / `b:`:
  // a bare single-letter prefix is brittle — a future business tag like
  // `b:backup` or `r:region-us` would accidentally light up with a
  // gradient. `spr:` / `spy:` / `spb:` reserves a dedicated namespace
  // that is unlikely to collide with real-world tag words.
  //
  // Shared design rules across all three families (keep in sync):
  //   • Saturation band: Tailwind **600**. Deep enough that white text
  //     keeps > 3:1 contrast on every stop (no text-shadow needed),
  //     light enough to still read as a coloured badge rather than a
  //     muddy pill. 600 also visually matches the grey UI tags next to
  //     it in weight, which was a hard-won result of earlier tuning.
  //   • Stop count: **3** only. Each stop gets ~9 px of a ~28 px short
  //     badge ("vip", "pro"), which is the maximum the eye reads as
  //     smooth flow rather than discrete bands.
  //   • Direction: 90deg horizontal, so the spectrum is laid across
  //     the badge's width rather than diagonally compressed into a
  //     middle-hue blob on short labels.
  //   • Family choice: every family starts on its prefix-named hue
  //     (r → red, y → yellow/amber, b → blue) and travels roughly 60°
  //     of hue in a direction that keeps all three stops in one tonal
  //     story (not a full rainbow). That is the compromise that
  //     satisfied earlier feedback: rainbow feel without banding, and
  //     tonal coherence so the badge reads as "one coloured object"
  //     not "three stripes".
  const RAINBOW_GRADIENTS = {
    // r: warm sunset — red → orange → pink. Energetic / warning-adjacent
    // feel but still decorative (pink end pulls it away from pure alert
    // red). Good for "hot", "priority", "danger"-flavoured labels.
    r: 'linear-gradient(90deg, ' +
      '#dc2626 0%, '   + // red-600
      '#ea580c 50%, '  + // orange-600
      '#db2777 100%'   + // pink-600
      ')',
    // y: golden meadow — amber → green → teal. Warm-to-cool neutral
    // bridge; feels "natural" / "balanced". Good for "standard",
    // "staff", "maintenance"-flavoured labels that are neither warning
    // nor premium.
    y: 'linear-gradient(90deg, ' +
      '#ca8a04 0%, '   + // amber-600 (deep gold, still legible on white)
      '#16a34a 50%, '  + // green-600
      '#0d9488 100%'   + // teal-600
      ')',
    // b: cosmic — blue → purple → fuchsia. Cool iridescent / "premium"
    // feel in line with Apple achievements / GitHub Sponsor badges.
    // Good for "vip", "pro", "enterprise"-flavoured labels.
    b: 'linear-gradient(90deg, ' +
      '#2563eb 0%, '   + // blue-600
      '#9333ea 50%, '  + // purple-600
      '#c026d3 100%'   + // fuchsia-600
      ')',
  };

