    // For speed tags, always consider them changed (speed is real-time and should update every cycle)
    const speedTagInChanged = oldItemNormalized.net_in_mb_s !== newItemNormalized.net_in_mb_s;
    const speedTagOutChanged = oldItemNormalized.net_out_mb_s !== newItemNormalized.net_out_mb_s;
    
    if (shouldUpdateAll || trafficTagTotalInChanged || trafficTagTotalOutChanged || speedTagInChanged || speedTagOutChanged) {
      // Find all traffic and speed tags in the details section
      // Update them regardless of whether the section is expanded or collapsed
      // This ensures tags show latest data when user expands the section
      const detailsSection = document.querySelector(`[data-details-id="${item.id}"]`);
      if (detailsSection) {
