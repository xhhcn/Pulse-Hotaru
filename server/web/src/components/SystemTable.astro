      // inside one microtask the browser only commits a single layout.
      if (loadingIndicator) loadingIndicator.style.display = 'none';

      body.innerHTML = items.map(item => renderRow(item, tcpingConfigured)).join('');
      currentData = newData;

      // Row-level stagger-in. Each row animates at the ALREADY-settled
      // column width (locked in STEP 1 of renderDataInternal), so the
      // fade-up is a pure opacity+translateY transition with zero
      // horizontal motion — the user sees rows "rise into place",
      // never "slide sideways".
      //
      // Gated by `staggerAnimationPlayed` so a transient empty payload
      // mid-session does NOT replay the animation: that scenario was
      // visible to the user as the whole list flickering in from the
      // top every few seconds.
      const systemRows = body.querySelectorAll('.system-row');
      if (!staggerAnimationPlayed) {
        staggerAnimationPlayed = true;
        systemRows.forEach((row, index) => {
          row.style.opacity = '0';
          row.style.animation = 'data-row-in 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards';
          row.style.animationDelay = `${index * 50}ms`;
          // Clean up after animation
          setTimeout(() => {
            row.style.opacity = '';
            row.style.animation = '';
            row.style.animationDelay = '';
          }, 400 + index * 50);
        });
      }

      await loadOSIcons();
      await loadFlagIcons();
      setupCopyButtons(body);
      setupRowClickHandlers(body);
      // Update translations after DOM is ready
      setTimeout(() => updateTranslations(), 0);
      return;
    }
    
    // Get existing rows - now looking for .system-row instead of [data-system-id]
    const existingRows = body.querySelectorAll('.system-row');
    const existingRowMap = new Map();
    existingRows.forEach(systemRow => {
      const rowElement = systemRow.querySelector('[data-system-id]');
      const id = rowElement?.dataset.systemId;
      if (id) {
        existingRowMap.set(id, rowElement);
      }
    });
    
    // Track which rows need updates
    let hasChanges = false;
    const rowsToUpdate = [];
    const rowsToAdd = [];
    const rowsToRemove = [];
    
    // Check for updates and new items
    items.forEach((item, index) => {
      const normalizedItem = newData.get(item.id);
      const oldItem = currentData.get(item.id);
      const existingRow = existingRowMap.get(item.id);
      
      if (!existingRow) {
        // New row needs to be added
        rowsToAdd.push({ item, index });
        hasChanges = true;
      } else if (hasChanged(oldItem, normalizedItem)) {
        // Existing row needs update - use original item for rendering
        rowsToUpdate.push({ row: existingRow, item: item });
        hasChanges = true;
      } else if (oldItem && oldItem.order !== normalizedItem.order) {
        // Order changed, need to reorder
        hasChanges = true;
      }
    });
    
    // Check for removed items
    currentData.forEach((oldItem, id) => {
      if (!newData.has(id)) {
        rowsToRemove.push(id);
        hasChanges = true;
      }
    });
    
    // Check if order changed (for sorting) - check BEFORE early return
    const currentOrder = Array.from(body.children).map(systemRow => {
      const rowElement = systemRow.querySelector('[data-system-id]');
      return rowElement?.dataset.systemId;
    }).filter(Boolean);
    const desiredOrder = items.map(item => item.id);
    const orderChanged = currentOrder.length === desiredOrder.length && 
                         JSON.stringify(currentOrder) !== JSON.stringify(desiredOrder);
    
    // Always update currentData first, before any DOM operations
    // This ensures that updateRow has access to the correct old data
    const previousData = new Map(currentData);
    currentData = newData;
    
    // If no changes AND order hasn't changed, skip update completely
    if (!hasChanges && !orderChanged && existingRows.length === items.length) {
      // Cache already updated above, just return
      return; // Silent skip - no DOM operations
    }
    
    // Remove deleted rows
    rowsToRemove.forEach(id => {
      const rowElement = existingRowMap.get(id);
      if (rowElement) {
        const systemRow = rowElement.closest('.system-row');
        if (systemRow) {
          systemRow.remove();
        } else {
          rowElement.remove();
        }
      }
    });
    
    // Update existing rows (only changed cells) - batch updates
    if (rowsToUpdate.length > 0) {
      rowsToUpdate.forEach(({ row, item }) => {
        // Get previous item data before updating
        const previousItem = previousData.get(item.id);
        updateRow(row, item, previousItem);
      });
      // Only load OS icons if OS changed
      const osChanged = rowsToUpdate.some(({ item }) => {
        const old = currentData.get(item.id);
        return old && old.os_icon !== item.os_icon;
      });
      if (osChanged) {
        setTimeout(() => loadOSIcons(), 0);
      }
      
      // Load flag icons if location changed
      const locationChanged = rowsToUpdate.some(({ item }) => {
        const old = currentData.get(item.id);
        return old && old.location !== item.location;
      });
      if (locationChanged) {
        setTimeout(() => loadFlagIcons(), 0);
      }
    }
    
    // Add new rows
    if (rowsToAdd.length > 0) {
      rowsToAdd.forEach(({ item, index }, addIndex) => {
        // Find insertion point
        let insertBefore = null;
        for (let i = index + 1; i < items.length; i++) {
          const nextId = items[i].id;
          const nextRow = body.querySelector(`[data-system-id="${nextId}"]`);
          if (nextRow) {
            insertBefore = nextRow;
            break;
          }
        }
        
        // Use cached tcping config status or check if needed
        const rowHTML = renderRow(item, tcpingConfigured);
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = rowHTML;
        const systemRowElement = tempDiv.firstElementChild;
        if (systemRowElement) {
          // Add entrance animation for new rows
          systemRowElement.classList.add('animate-scale-in');
          systemRowElement.style.animationDelay = `${addIndex * 50}ms`;
          
          // Find the system-row to insert before
          let insertBeforeSystemRow = null;
          if (insertBefore) {
            insertBeforeSystemRow = insertBefore.closest('.system-row');
          }
          if (insertBeforeSystemRow) {
            body.insertBefore(systemRowElement, insertBeforeSystemRow);
          } else {
            body.appendChild(systemRowElement);
          }
          
          // Clean up animation class after animation completes
          setTimeout(() => {
            systemRowElement.classList.remove('animate-scale-in');
            systemRowElement.style.animationDelay = '';
          }, 300 + addIndex * 50);
        }
      });
      
      await loadOSIcons();
      await loadFlagIcons();
      setupCopyButtons(body);
      setupRowClickHandlers(body);
      // Update translations after DOM is ready
      setTimeout(() => updateTranslations(), 0);
      // Recalculate column width when new rows are added (names might be longer)
      setTimeout(() => recalculateColumnWidthFromCurrentData(), 0);
    }
    
    // Handle reordering if needed - ALWAYS check order, even if no other changes
    // This ensures sorting works correctly
    if (orderChanged) {
      // Reorder rows without full re-render
      const rowMap = new Map();
      Array.from(body.children).forEach(systemRow => {
        const rowElement = systemRow.querySelector('[data-system-id]');
        const id = rowElement?.dataset.systemId;
        if (id) {
          rowMap.set(id, systemRow);
        }
      });
      
      // Re-append in correct order
      items.forEach(item => {
        const row = rowMap.get(item.id);
        if (row && row.parentNode) {
          body.appendChild(row); // appendChild moves existing element
        }
      });
    }
    
    // Cache already updated at the beginning of the function
    
    // Recalculate column width if rows were added or names changed
    if (rowsToAdd.length > 0 || rowsToUpdate.some(({ item }) => {
      const old = previousData.get(item.id);
      return old && old.name !== item.name;
    })) {
      setTimeout(() => recalculateColumnWidthFromCurrentData(), 0);
    }
  };

  // renderData is the single, self-serialized render path for the table.
  //
  // Any number of callers (initial load, user filter/sort, SSE push, admin
  // mutations, refresh button, …) may invoke it concurrently. To keep DOM
  // updates atomic, renderData guards itself with an in-flight flag and a
  // "latest-wins" pending slot. If a second call arrives while one is still
  // running, its payload is stored in `pendingRenderData`, overwriting any
  // earlier pending payload. When the current render finishes, the loop
  // drains the pending slot and runs one more render with the newest data.
  //
  // This gives three important guarantees:
  //   1. DOM mutations never interleave from two concurrent renders.
  //   2. Rapid bursts of events collapse into at most 2 renders (current +
  //      latest pending), regardless of how many events fired.
  //   3. The freshest state always wins — a later event never gets shadowed
  //      by an earlier one that finishes render later.
  //
  // Because every SSE event we consume carries the FULL authoritative
  // systems list, simply overwriting pendingRenderData is always safe —
  // the newer payload fully supersedes the older one.
  let isRenderRunning = false;
  let pendingRenderData = null;
  async function renderData(data) {
    if (!Array.isArray(data)) return;

    if (isRenderRunning) {
      // Latest-wins: drop any earlier pending payload in favour of this one.
      pendingRenderData = data;
      return;
    }

    isRenderRunning = true;
    try {
      let current = data;
      // Drain pending slot before returning — if new renders are requested
      // while the current one is in progress, we serve the newest one next
      // before releasing the lock.
      while (current) {
        try {
          await renderDataInternal(current);
        } catch (err) {
          if (loadingIndicator) {
            loadingIndicator.innerHTML = `
              <div class="text-center">
                <p class="text-sm text-red-500 dark:text-red-400">Failed to render data</p>
                <p class="text-xs text-[#737373] dark:text-[#a3a3a3] mt-1">${err.message}</p>
              </div>
            `;
          }
        }
        current = pendingRenderData;
        pendingRenderData = null;
      }
    } finally {
      isRenderRunning = false;
    }
  }

  // Latch set the first time we actually render ANY data (either from an
  // SSE push or a fallback loadData fetch). Used by the initial-load watcher
  // below to decide whether to fall back to a one-shot GET.
  let initialDataRendered = false;

  // Internal render implementation — assumed to be called serially from
  // renderData() only. Never call this directly.
  async function renderDataInternal(data) {
    initialDataRendered = true;
    if (data.length === 0) {
      showEmpty();
      // Materialise the header (it ships as display:none during the
      // pulse phase — see STEP 2 below for the full rationale). Even
      // though there are no rows to measure, we still want the header
      // visible so the empty-state message is framed by the proper
      // column labels. The default 160 px --first-col-width is
      // appropriate here because no row ever forces it wider.
      const headerRow = document.getElementById('system-table-header-row');
      if (headerRow) {
        headerRow.style.display = 'grid';
        void headerRow.offsetHeight;
        headerRow.style.opacity = '1';
      }
      return;
    }

    // STEP 1 — Lock the column width BEFORE any pixels are painted that
    // depend on it. calculateServerNameColumnWidth measures every name
    // via an off-screen span, so the resulting --first-col-width is the
    // final value; it will only grow from here if/when a longer name
    // registers in a later SSE frame (which is a steady-state update,
    // not an initial-load concern). applyServerNameColumnWidth ends
    // with a forced reflow, so by the time this line returns the CSS
    // variable has been committed to the computed style tree.
    const preCalculatedWidth = calculateServerNameColumnWidth(data);
    applyServerNameColumnWidth(preCalculatedWidth);

    // STEP 2 — On the very first render, materialise the header.
    //
    // The header row ships with inline `display: none; opacity: 0` so
    // it is completely absent from layout during the pulse phase —
    // crucially, the user never sees a header at the wrong (default
    // 160 px) column width. STEP 1 above has already measured every
    // server name and committed the correct `--first-col-width` to
    // the style tree via a forced reflow, so the moment we flip the
    // header back to `display: grid` its columns are drawn at their
    // final, data-driven widths. A second forced reflow here makes
    // sure the display switch is committed BEFORE we touch opacity,
    // otherwise the browser is free to batch the two style changes
    // and skip the opacity transition entirely (rendering the header
    // as an abrupt pop-in). With the reflow in place the sequence
    // the user sees is: pulse rows breathing → pulse vanishes → the
    // table header fades in at its correct width → rows slot in
    // underneath at the same, settled column positions. No part of
    // the header is ever visible at the wrong width.
    if (currentData.size === 0) {
      const headerRow = document.getElementById('system-table-header-row');
      if (headerRow) {
        headerRow.style.display = 'grid';
        void headerRow.offsetHeight;
        headerRow.style.opacity = '1';
      }

      // STEP 3 — Wait one paint frame before handing off to render().
      //
      // STEP 1 already forced a synchronous reflow, so the width is
      // authoritative in the style tree. But the *paint* of that new
      // width (i.e. the pixels the user actually sees) happens on the
      // next frame. By yielding one rAF here we guarantee that the
      // fresh column width has been rasterised to the screen before the
      // row-level `data-row-in` keyframe starts. The net effect for the
      // user is: nothing moves during the row fade-up — rows simply
      // materialise at their final, correct column positions.
      //
      // Cost: ~16 ms on a 60 Hz display. That is well below the
      // perception threshold and does not lengthen the feel of the load
      // (the pulsing placeholder bars in LoadingState keep filling the
      // space during this frame).
      await new Promise(resolve => requestAnimationFrame(() => resolve()));
    }

    // Apply filter first, then sorting
    const filteredData = filterSystems(data);
    const sortedData = sortSystems(filteredData);
    await render(sortedData);
  }

  // loadData is kept as the entry point for the cases where the browser
  // legitimately needs to fetch state on its own:
  //   * initial page load (before any SSE event has arrived)
  //   * user actions (filter / sort / refresh button / legacy signal events)
  //
  // The real-time realtime path (every 3 s, plus admin mutations) is the
  // SSE `metric_updated` event which embeds the systems array directly and
  // calls renderData() without any fetch.
  async function loadData() {
    try {
      const data = await fetchSystemMetrics(apiBase);
      await renderData(data);
    } catch (err) {
      if (loadingIndicator) {
        loadingIndicator.innerHTML = `
          <div class="text-center">
            <p class="text-sm text-red-500 dark:text-red-400">Failed to connect to backend</p>
            <p class="text-xs text-[#737373] dark:text-[#a3a3a3] mt-1">${err.message}</p>
          </div>
        `;
      }
      // Materialise the header at the default 160 px --first-col-width
      // so the error message has the proper column frame around it.
      // The display:none→grid + reflow + opacity trick mirrors the
      // happy-path STEP 2, so the failure UI fades in with the same
      // curve as success.
      const headerRow = document.getElementById('system-table-header-row');
      if (headerRow) {
        headerRow.style.display = 'grid';
        void headerRow.offsetHeight;
        headerRow.style.opacity = '1';
      }
    }
  }

  // debouncedRenderData collapses rapid-fire SSE events into a single render
  // with an 80 ms window. This is primarily a CPU optimisation — renderData
  // is already self-serialising, but we avoid scheduling 10 microtasks in a
  // row when several SSE frames arrive back-to-back.
  let renderTimeout = null;
  const debouncedRenderData = (data) => {
    // Pre-populate the latest-wins slot so the next renderData call — which
    // may be the one we schedule below, or one triggered by a user action —
    // always picks up this payload.
    pendingRenderData = data;
    if (renderTimeout) return;
    renderTimeout = setTimeout(() => {
      renderTimeout = null;
      const d = pendingRenderData;
      pendingRenderData = null;
      if (d) renderData(d);
    }, 80);
  };

  // Legacy fallback: older signal-only events (e.g. order_updated) still fall
  // back to a fetch + render. This is only used for events that do NOT carry
  // the systems array; the common metric_updated path never hits here.
  let loadDataTimeout = null;
  let isLoadDataRunning = false;
  const debouncedLoadData = () => {
    if (isLoadDataRunning) return;
    if (loadDataTimeout) {
      clearTimeout(loadDataTimeout);
    }
    loadDataTimeout = setTimeout(async () => {
      if (isLoadDataRunning) {
        loadDataTimeout = null;
        return;
      }
      isLoadDataRunning = true;
      try {
        await loadData();
      } finally {
        isLoadDataRunning = false;
        loadDataTimeout = null;
      }
    }, 200);
  };

  // Connect to SSE for real-time updates
  //
  // Reliability strategy:
  //   * Exponential backoff with jitter on reconnect, to avoid a thundering
  //     herd when the backend restarts and many browser tabs reconnect at once.
  //   * A liveness watchdog that forces a reconnect if we haven't seen any
  //     SSE traffic in 45 s. The server sends either an update (every ~3 s)
  //     or a keepalive ping (every 15 s), so 45 s of silence is a strong
  //     signal that the TCP stream is half-open (mobile network switch,
  //     NAT idle timeout, etc.) and needs to be re-established proactively —
  //     EventSource alone can take several minutes to notice.
  let sseReconnectAttempt = 0;
  let sseWatchdogTimer = null;
  const SSE_WATCHDOG_MS = 45_000;

  function markSSEAlive() {
    if (sseWatchdogTimer) {
      clearTimeout(sseWatchdogTimer);
    }
    sseWatchdogTimer = setTimeout(() => {
      // No activity (not even the 15 s server keepalive) for 45 s — force
      // a reconnect. Using the error path reuses the same backoff logic.
      if (eventSource) {
        try { eventSource.close(); } catch (_) {}
        eventSource = null;
      }
      scheduleSSEReconnect();
    }, SSE_WATCHDOG_MS);
  }

  function scheduleSSEReconnect() {
    // Exponential backoff: 1s, 2s, 4s, 8s, 16s, capped at 30s, + up to 1s jitter.
    const base = Math.min(30_000, 1000 * Math.pow(2, sseReconnectAttempt));
    const jitter = Math.floor(Math.random() * 1000);
    const delay = base + jitter;
    sseReconnectAttempt++;
    setTimeout(connectSSE, delay);
  }

  function connectSSE() {
    // Close existing connection and remove all event listeners
    if (eventSource) {
      eventSource.close();
      eventSource = null;
    }
    if (sseWatchdogTimer) {
      clearTimeout(sseWatchdogTimer);
      sseWatchdogTimer = null;
    }

    // Get token from URL parameter (for share links) or admin token
    const urlParams = new URLSearchParams(window.location.search);
    const shareToken = urlParams.get('token');
    const adminToken = localStorage.getItem('admin_auth_token');
    
    // Build SSE URL with token if available (EventSource doesn't support custom headers)
    let sseUrl = `${apiBase}/api/events`;
    if (shareToken) {
      sseUrl += `?token=${encodeURIComponent(shareToken)}`;
    } else if (adminToken) {
      // For admin token, we need to pass it via URL since EventSource doesn't support headers
      // Note: This is less secure, but EventSource limitation
      sseUrl += `?admin_token=${encodeURIComponent(adminToken)}`;
    }

    eventSource = new EventSource(sseUrl);
    markSSEAlive();

    eventSource.addEventListener('connected', (e) => {
      // Successfully (re)connected — reset the backoff counter so the next
      // unrelated disconnect starts over at 1 s.
      sseReconnectAttempt = 0;
      markSSEAlive();
    });

    // onmessage fires for untyped messages AND for the server keepalive
    // stream; use it purely to reset the watchdog. Typed events have their
    // own listeners below.
    eventSource.onmessage = () => {
      markSSEAlive();
    };

    // Store the handler function so we can remove it if needed.
    //
    // Backend-push model:
    //   * metric_updated events now embed the full systems list in
    //     `update.systems`. When present, the browser renders directly from
    //     that data and does NOT issue GET /api/metrics. This eliminates the
    //     redundant fetch round-trip and makes the server the single source
    //     of truth for what each tab displays.
    //   * metric_deleted / order_updated remain signal-only events. They
    //     don't carry data on the wire, so we keep the legacy fallback of
    //     fetching once before rendering for those two. (Newer server
    //     versions also emit a full-data metric_updated right after the
    //     signal, which will arrive within a few ms and supersede the
    //     fetched result.)
    const updateHandler = (e) => {
      markSSEAlive();
      try {
        const update = JSON.parse(e.data);

        if (update.type === 'metric_updated') {
          if (Array.isArray(update.systems)) {
            // Backend-pushed full state — render directly, no GET.
            debouncedRenderData(update.systems);
          } else {
            // Legacy signal-only event from an older server — fall back.
            debouncedLoadData();
          }
        } else if (update.type === 'order_updated' || update.type === 'metric_deleted') {
          // Signal-only events → fetch once to converge. (On newer servers
          // the following metric_updated will land within milliseconds and
          // refresh again with embedded data; that's harmless.)
          debouncedLoadData();
        } else if (update.type === 'tcping_config_updated') {
          // Admin changed the tcping config (added/removed/renamed a
          // target). Our cachedTCPingConfig is now stale, and any
          // currently-expanded chart is drawing a target set that no
          // longer matches reality. Drop the cache, re-fetch the fresh
          // config, and redraw tabs + chart for every expanded row so
          // deleted targets disappear immediately (no "ghost first
          // point" left over) and newly added targets show up without
          // a page reload.
          handleTCPingConfigUpdated();
          return;
        } else {
          return; // unknown event type — ignore
        }

        // Refresh tcping charts for visible expanded rows, but ONLY when the
        // underlying tcping_data has actually changed.
        //
        // Why this matters: metric_updated events are broadcast every 3 s
        // (the service uptime / CPU / RAM cadence), while tcping latency is
        // sampled at the admin-configured interval (default 60 s, can be
        // 10 s / 30 s / etc.). Calling updateTCPingChart on EVERY 3 s frame
        // would cause the chart to re-fetch history and redraw 3–20× more
        // often than there is actual new data, producing visible flicker
        // and wasted HTTP traffic. Instead we hash the tcping_data
        // timestamps of each expanded system and only refresh when that
        // signature changes — giving us "exactly as often as there is new
        // tcping data", which IS the admin-configured interval.
        // If a tcping_config_updated just landed, handleTCPingConfigUpdated
        // is already tearing down and rebuilding every expanded chart.
        // Racing a second redraw from this branch would double-fetch the
        // history and risk creating two Chart.js instances on the same
        // canvas, so defer to the in-flight rebuild.
        if (tcpingConfigUpdatePending) {
          return;
        }
        const expandedSections = document.querySelectorAll('.system-details:not(.hidden)');
        if (expandedSections.length > 0) {
          // Build a quick lookup only when we actually need it.
          const systemsById = (update && Array.isArray(update.systems))
            ? new Map(update.systems.map(s => [s.id, s]))
            : null;
          expandedSections.forEach(detailsSection => {
            const systemId = detailsSection.dataset.detailsId;
            if (!systemId) return;

            const loadingState = tcpingLoadingStates.get(systemId);
            if (loadingState && loadingState.loading) return;

            const systemData = systemsById ? systemsById.get(systemId) : null;
            if (!systemData) {
              // Legacy signal-only event (no systems array) — fall back to a
              // single refresh so user edits propagate at least once.
              updateTCPingChart(systemId, null, null, true);
              return;
            }

            const newSig = computeTCPingSignature(systemData);
            const oldSig = tcpingDataSignatures.get(systemId) || '';
            if (newSig === oldSig) {
              // No tcping target has produced a new timestamp — nothing
              // fresh to draw. Skip the fetch entirely.
              return;
            }
            tcpingDataSignatures.set(systemId, newSig);
            updateTCPingChart(systemId, null, null, true);
          });
        }
      } catch (err) {
        // SSE parse error silently
      }
    };
    
    eventSource.addEventListener('update', updateHandler);

    eventSource.onerror = (err) => {
      if (eventSource) {
        eventSource.close();
        eventSource = null;
      }
      if (sseWatchdogTimer) {
        clearTimeout(sseWatchdogTimer);
        sseWatchdogTimer = null;
      }
      scheduleSSEReconnect();
    };
  }

  // Setup filter input handler - prevent duplicate event listeners
  let filterInputHandlersSetup = false;
  function setupFilterInput() {
    const filterInput = document.getElementById('system-filter-input');
    if (!filterInput || filterInputHandlersSetup) return; // Already setup, skip

    const inputHandler = (e) => {
      currentFilter = e.target.value;
      // Reload data to apply filter
      loadData();
    };

    const keydownHandler = (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        currentFilter = e.target.value;
        loadData();
      }
    };

    filterInput.addEventListener('input', inputHandler);
    filterInput.addEventListener('keydown', keydownHandler);
    filterInputHandlersSetup = true;
  }

  // Initial bootstrap. The data source is 100% server-push: when the SSE
  // connection opens, the server immediately sends an authoritative snapshot
  // and then pushes every 3 s plus on every admin mutation. The browser
  // therefore has ZERO self-initiated polling; the only thing we add here is
  // a one-shot safety net in case the SSE stream fails to deliver within a
  // short grace window (proxy that strips SSE, firewall, or server hiccup),
  // in which case we fall back to a single GET /api/metrics.
  const INITIAL_SSE_FALLBACK_MS = 2500;
  async function bootstrap() {
    setupFilterInput();
    await loadTrafficSetting();
    connectSSE();
    updateTranslations();
    preloadTCPingConfig();

    // One-shot fallback: if no render has happened by the deadline, pull
    // once so the page isn't stuck on "loading". On a healthy connection
    // the SSE initial snapshot fires within ~100–200 ms and this timer
    // never triggers.
    setTimeout(() => {
      if (!initialDataRendered) {
        loadData();
      }
    }, INITIAL_SSE_FALLBACK_MS);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootstrap);
  } else {
    bootstrap();
  }

  // Recalculate column width on window resize (with debounce)
  let resizeTimeout = null;
  window.addEventListener('resize', () => {
    if (resizeTimeout) {
      clearTimeout(resizeTimeout);
    }
    resizeTimeout = setTimeout(() => {
      recalculateColumnWidthFromCurrentData();
      // Rotating the phone / resizing the browser changes the chart's CSS
      // box width (inside horizontally-scrollable table). Chart.js does not
      // always observe that layout shift reliably on mobile Safari — give it
      // an explicit resize after column math settles.
      tcpingCharts.forEach(({ chart }) => {
        try {
          if (chart && typeof chart.resize === 'function') chart.resize();
        } catch (_) {}
      });
      resizeTimeout = null;
    }, 250);
  });

  window.addEventListener('orientationchange', () => {
    // Same rationale as resize — orientation fires slightly ahead of layout
    // on some WebViews; trigger after the next paint.
    requestAnimationFrame(() => {
      setTimeout(() => {
        tcpingCharts.forEach(({ chart }) => {
          try {
            if (chart && typeof chart.resize === 'function') chart.resize();
          } catch (_) {}
        });
      }, 100);
    });
  });

  window.addEventListener('beforeunload', () => {
    if (eventSource) {
      eventSource.close();
    }
  });
</script>

<style is:global>
  /* Column width management for table */
  #monitor-root {
    --first-col-width: 160px;
  }
  
  
  @keyframes data-row-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* TCPing target tabs — faster taps on mobile (no double-tap zoom delay). */
  [data-tcping-tabs] button {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
</style>
