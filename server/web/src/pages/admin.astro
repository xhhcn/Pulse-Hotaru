---
import '../styles/global.css';
import '../styles/hotaru-theme.css';
import AdminDashboard from '../components/AdminDashboard.astro';
import Footer from '../components/Footer.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE ?? '';
---

<!--
  Admin page — fully aligned with the hotaru theme:
    • light only (no dark mode classes anywhere)
    • Chinese only (no language toggle)
    • no navbar — actions are in the AdminDashboard toolbar

  AdminDashboard.astro is reused as-is (it carries all admin
  functionality). Every Tailwind `dark:` variant has been stripped
  from that component, so the compiled CSS no longer ships any
  dark-mode rules; the page is light-only end-to-end.
-->
<html lang="zh-CN" class="light overflow-x-hidden" data-api-base={apiBase}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Pulse Monitor 管理控制台" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#fafafa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#24292f" />
    <title>管理 · Pulse Monitor</title>
    <script is:inline>
      (function () {
        // Light-mode + zh-CN locked at the source. Forced regardless of
        // any stale `preferred-language` / `preferred-theme` value the
        // user may have stored from an earlier build.
        document.documentElement.lang = 'zh-CN';
        document.documentElement.classList.add('light');
        document.documentElement.classList.remove('dark');
        try { localStorage.setItem('preferred-language', 'zh'); } catch (_) {}
        try { localStorage.setItem('preferred-theme', 'light'); } catch (_) {}

        function applyBody() {
          const body = document.body;
          if (body) {
            body.classList.add('light');
            body.classList.remove('dark');
          } else {
            requestAnimationFrame(applyBody);
          }
        }
        applyBody();

        // Preload navbar config for title / favicon only — we don't
        // render a navbar here, but the operator's branded title and
        // logo are still applied for consistency with the public page.
        const apiBase = window.location.origin;
        fetch(`${apiBase}/api/navbar/config`)
          .then((res) => (res.ok ? res.json() : null))
          .then((config) => {
            if (!config) return;
            window.__navbarConfig = config;
            if (config.text) document.title = `管理 · ${config.text}`;
            if (config.logo) {
              const favicon = document.querySelector('link[rel="icon"]');
              if (favicon) {
                favicon.href = config.logo;
                const ext = config.logo.toLowerCase().split('.').pop().split('?')[0];
                if (ext === 'svg') favicon.type = 'image/svg+xml';
                else if (ext === 'png') favicon.type = 'image/png';
                else if (ext === 'jpg' || ext === 'jpeg') favicon.type = 'image/jpeg';
                else if (ext === 'ico') favicon.type = 'image/x-icon';
                else favicon.removeAttribute('type');
              }
            }
          })
          .catch(() => {});
      })();
    </script>
    <!-- Operator-supplied custom CSS / JS hook (sync XHR so injected
         <script> tags load before DOMContentLoaded). -->
    <script is:inline>
      (function () {
        try {
          var xhr = new XMLHttpRequest();
          xhr.open('GET', '/api/navbar/config', false);
          xhr.send();
          if (xhr.status !== 200) return;
          var config = JSON.parse(xhr.responseText);
          if (config.custom_css && config.custom_css.trim()) {
            var style = document.createElement('style');
            style.textContent = config.custom_css;
            document.head.appendChild(style);
          }
          if (config.custom_js && config.custom_js.trim()) {
            var customJS = config.custom_js;
            var scriptTagRegex = /<script([^>]*)>([\s\S]*?)<\/script>/gi;
            var matches = [];
            var m;
            while ((m = scriptTagRegex.exec(customJS)) !== null) {
              matches.push({ attrs: m[1], content: m[2] });
            }
            if (matches.length > 0) {
              matches.forEach(function (data) {
                var s = document.createElement('script');
                var srcMatch = data.attrs.match(/src=["']([^"']+)["']/);
                if (srcMatch) {
                  s.src = srcMatch[1];
                  s.async = false;
                  s.defer = false;
                } else if (data.content.trim()) {
                  s.textContent = data.content;
                }
                if (s.src || s.textContent) document.head.appendChild(s);
              });
            } else {
              var s = document.createElement('script');
              s.textContent = customJS;
              document.head.appendChild(s);
            }
          }
        } catch (err) {
          console.warn('Failed to load custom styles:', err);
        }
      })();
    </script>
  </head>
  <body class="hotaru-theme light min-h-screen">
    <div id="auth-check" class="hotaru-admin-shell" hidden>
      <main>
        <AdminDashboard apiBase={apiBase} />
      </main>
      <Footer />
    </div>

    <!--
      Auth-gate overlay — same cross-fade pattern as before but
      without dark variants. White hotaru bg + neutral spinner.
    -->
    <div id="login-redirect" class="hotaru-auth-redirect">
      <div class="hotaru-auth-redirect__inner">
        <p class="hotaru-auth-redirect__text">
          正在校验登录状态<span class="hotaru-auth-redirect__ellipsis" aria-hidden="true"><span>.</span><span>.</span><span>.</span></span>
        </p>
      </div>
    </div>
  </body>
</html>

<style>
  /* Page-local styles for the auth-gate overlay. Kept out of the
     global hotaru-theme.css since they only apply on this page.    */
  .hotaru-auth-redirect {
    position: fixed;
    inset: 0;
    z-index: 9990;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    transition: opacity 0.2s ease-out;
  }
  .hotaru-auth-redirect__inner {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hotaru-auth-redirect__text {
    margin: 0;
    color: #616366;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }
  .hotaru-auth-redirect__ellipsis {
    display: inline-block;
    width: 1em;
    text-align: left;
    letter-spacing: 0.05em;
  }
  .hotaru-auth-redirect__ellipsis > span {
    opacity: 0;
    animation: 1.4s steps(1, end) infinite;
  }
  .hotaru-auth-redirect__ellipsis > span:nth-child(1) { animation-name: hotaru-ellipsis-1; }
  .hotaru-auth-redirect__ellipsis > span:nth-child(2) { animation-name: hotaru-ellipsis-2; }
  .hotaru-auth-redirect__ellipsis > span:nth-child(3) { animation-name: hotaru-ellipsis-3; }
</style>

<script>
  function getApiBase() {
    const root = document.documentElement;
    if (root?.dataset?.apiBase && root.dataset.apiBase.trim() !== '') {
      return root.dataset.apiBase.trim();
    }
    return window.location.origin;
  }

  const apiBase = getApiBase();

  (async () => {
    const authCheck     = document.getElementById('auth-check');
    const loginRedirect = document.getElementById('login-redirect');

    /* If no admin password has been set yet, route the visitor
       through /login so they can configure one. */
    try {
      const statusRes = await fetch(`${apiBase}/api/auth/status`);
      if (statusRes.ok) {
        const statusData = await statusRes.json();
        if (!statusData.set) {
          window.location.href = '/login?redirect=/admin';
          return;
        }
      }
    } catch (_) {}

    const token = localStorage.getItem('admin_auth_token');
    if (!token) {
      window.location.href = '/login?redirect=/admin';
      return;
    }

    try {
      const res = await fetch(`${apiBase}/api/auth/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });
      if (!res.ok) throw new Error('verify failed');
      const data = await res.json();
      if (!data.valid) throw new Error('token invalid');

      // Show the dashboard, fade the overlay out.
      authCheck.removeAttribute('hidden');
      loginRedirect.style.pointerEvents = 'none';
      loginRedirect.style.opacity = '0';
      setTimeout(() => loginRedirect.setAttribute('hidden', ''), 220);

      // Inject the auth token into all subsequent fetch calls so
      // AdminDashboard's API calls authenticate transparently.
      const originalFetch = window.fetch;
      window.fetch = function (...args) {
        const [url, options = {}] = args;
        if (typeof url === 'string' && (url.startsWith(apiBase) || url.startsWith('/api/'))) {
          options.headers = {
            ...options.headers,
            Authorization: `Bearer ${token}`,
          };
        }
        return originalFetch.apply(this, [url, options]);
      };
    } catch (_) {
      localStorage.removeItem('admin_auth_token');
      window.location.href = '/login?redirect=/admin';
    }
  })();
</script>
