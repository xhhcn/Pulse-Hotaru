---
import '../styles/hotaru-theme.css';
import HotaruServerTable  from '../components/HotaruServerTable.astro';
import HotaruUpdateTime   from '../components/HotaruUpdateTime.astro';
import HotaruCardGrid     from '../components/HotaruCardGrid.astro';

// Optional override for the API base URL via build-time env. The
// runtime script defaults to window.location.origin which is what
// the embedded Go backend uses, so this is rarely needed.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? '';
---

<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Pulse Monitor — lightweight server status dashboard." />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="googlebot" content="noindex, nofollow" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="color-scheme" content="light" />
  <!-- Match the actual hotaru body background (`body.hotaru-theme {
       background: #ffffff }`). The earlier #fbf6f7 was a faint pink
       holdover from the pre-hotaru palette and made mobile browser
       chrome render with a warm tint that didn't match the page. -->
  <meta name="theme-color" content="#ffffff" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Server Status</title>

  <!-- Force light mode: clear any leftover .dark from previous
       Pulse builds before the body paints, so the hotaru palette
       renders on a pristine surface. Also load the navbar config
       (logo, custom CSS/JS, hide_cards toggle) early — the
       synchronous XHR is deliberate so the rest of the page can
       rely on `window.__navbarConfig` without races. -->
  <script is:inline>
    (function () {
      try {
        const html = document.documentElement;
        html.classList.remove('dark');
        html.classList.add('light');
        // Honour stored language pref (zh / en); default to system.
        const stored = localStorage.getItem('preferred-language');
        if (stored === 'zh' || stored === 'en') {
          html.lang = stored;
        } else {
          const sys = (navigator.language || '').toLowerCase();
          html.lang = sys.startsWith('zh') ? 'zh' : 'en';
        }
      } catch (_) {}

      try {
        const xhr = new XMLHttpRequest();
        xhr.open('GET', '/api/navbar/config', false);
        xhr.send();
        if (xhr.status === 200) {
          const cfg = JSON.parse(xhr.responseText);
          window.__navbarConfig = cfg;
          if (cfg.text) document.title = cfg.text;
          if (cfg.logo) {
            const link = document.querySelector('link[rel="icon"]');
            if (link) link.href = cfg.logo;
          }
          if (cfg.custom_css && cfg.custom_css.trim()) {
            const s = document.createElement('style');
            s.textContent = cfg.custom_css;
            document.head.appendChild(s);
          }
          if (cfg.custom_js && cfg.custom_js.trim()) {
            /* Compatibility layer for admin "自定义代码":
               - Historical saves may store raw JS (no <script> wrapper)
               - Newer saves can store one or more full <script> tags
                 (including external src=... tags)
               Running the payload as plain text unconditionally breaks
               the second case with "Unexpected token '<'".

               IMPORTANT: this loader runs in <head> before <body> exists.
               Many custom snippets append UI into document.body, so we
               defer execution until DOMContentLoaded to guarantee body is
               available and avoid null dereference crashes. */
            var runCustomJS = function () {
              var customJS = cfg.custom_js;
              var scriptTagRegex = /<script([^>]*)>([\s\S]*?)<\/script>/gi;
              var matches = [];
              var m;
              while ((m = scriptTagRegex.exec(customJS)) !== null) {
                matches.push({ attrs: m[1], content: m[2] });
              }
              if (matches.length > 0) {
                matches.forEach(function (data) {
                  var s = document.createElement('script');
                  var srcMatch = data.attrs.match(/src=["']([^"']+)["']/);
                  if (srcMatch) {
                    s.src = srcMatch[1];
                    s.async = false;
                    s.defer = false;
                  } else if (data.content.trim()) {
                    s.textContent = data.content;
                  }
                  if (s.src || s.textContent) document.head.appendChild(s);
                });
              } else {
                var s = document.createElement('script');
                s.textContent = customJS;
                document.head.appendChild(s);
              }
            };
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', runCustomJS, { once: true });
            } else {
              runCustomJS();
            }
          }
          /* Honour the "显示首页卡片" admin toggle by injecting a
             hard CSS rule before the <body> paints. Doing this in
             the synchronous early-script block (this XHR is
             intentionally synchronous so the rest of the page
             can rely on cfg without races) means the card grid
             never flashes into view and is then hidden — it
             simply renders display:none from the first frame.   */
          if (cfg.hide_cards === true) {
            const s = document.createElement('style');
            s.textContent = '.hotaru-cards-section { display: none !important; }';
            document.head.appendChild(s);
          }
        }
      } catch (_) {
        // No navbar config — continue with defaults.
      }
    })();
  </script>
</head>

<body class="hotaru-theme" data-api-base={apiBase}>
  <!-- Full-page initial loader. Sits fixed-positioned over a hidden
       <main> until the first metrics response (success OR failure)
       arrives, then fades out and reveals the content beneath.
       HotaruServerTable's render() / showError() both call
       window.__dismissHotaruLoader() to trigger the cross-fade.   -->
  <div class="hotaru-initial-loader" id="hotaru-initial-loader" role="status" aria-label="Loading">
    <span class="hotaru-initial-loader__text"
      >Loading<span class="hotaru-initial-loader__ellipsis" aria-hidden="true"
        ><span>.</span><span>.</span><span>.</span></span
      ></span>
  </div>

  <main class="hotaru-app" id="hotaru-app">
    <div class="hotaru-container hotaru-container--top">
      <HotaruServerTable />
      <HotaruUpdateTime />
    </div>
    <HotaruCardGrid />
  </main>

  <!-- Footer intentionally empty: the user asked to drop both the
       "Powered by Pulse" line and the hotaru attribution. Keeping
       the element as a structural placeholder so any sibling /
       layout rules that rely on a <footer> still resolve.       -->
  <footer class="hotaru-footer hotaru-container" aria-hidden="true"></footer>

  <!-- Silent auth check — no UI, just a background privacy gate -->
  <script is:inline>
    (function () {
      const isZh = () => (document.documentElement.lang || '').toLowerCase().startsWith('zh');

      function applyDocI18n() {
        document.querySelectorAll('[data-zh][data-en]').forEach((el) => {
          if (el.children.length === 0) {
            el.textContent = isZh() ? el.dataset.zh : el.dataset.en;
          }
        });
      }
      applyDocI18n();
      document.addEventListener('pulse:language-changed', applyDocI18n);

      function redirectLogin() {
        window.location.href = '/login?redirect=/';
      }

      const url = new URL(window.location.href);
      const shareToken = url.searchParams.get('token');
      const adminToken = localStorage.getItem('admin_auth_token');

      // Background privacy check — fails open so a broken backend
      // doesn't brick the dashboard. The page is already rendered;
      // we only redirect if privacy is on AND we have no valid auth.
      fetch('/api/privacy/config', { cache: 'no-store' })
        .then((r) => r.ok ? r.json() : null)
        .then((cfg) => {
          if (!cfg || !cfg.enabled) return;
          if (!shareToken && !adminToken) { redirectLogin(); return; }
          if (shareToken) {
            return fetch('/api/privacy/verify-token', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token: shareToken })
            }).then((r) => r.ok ? r.json() : null)
              .then((v) => { if (!v || !v.valid) redirectLogin(); });
          }
          return fetch('/api/auth/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: adminToken })
          }).then((r) => r.ok ? r.json() : null)
            .then((v) => { if (!v || !v.valid) redirectLogin(); });
        })
        .catch(() => { /* fail open */ });
    })();

    // Translation event — when language toggles elsewhere in the app
    // (or via storage) we rebroadcast so listeners can repaint.
    window.addEventListener('storage', (e) => {
      if (e.key === 'preferred-language') {
        document.documentElement.lang = e.newValue || 'en';
        document.dispatchEvent(new Event('pulse:language-changed'));
      }
    });
  </script>
</body>
</html>
