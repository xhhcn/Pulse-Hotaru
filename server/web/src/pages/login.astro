---
import '../styles/global.css';
import '../styles/hotaru-theme.css';
import LoginForm from '../components/LoginForm.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE ?? '';
---

<!--
  Login page — fully aligned with the hotaru theme:
    • light only (no dark mode classes anywhere)
    • Chinese only (no language toggle, no English fallback)
    • no navbar (intentional — login is a single-purpose page)
    • white card on hotaru's tiled bg, same drop shadow / radius
      vocabulary as the public dashboard cards
-->
<html lang="zh-CN" class="overflow-x-hidden" data-api-base={apiBase}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Pulse Monitor 管理员登录" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#fafafa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#24292f" />
    <title>登录 · Pulse Monitor</title>
    <script is:inline>
      (function () {
        document.documentElement.lang = 'zh-CN';
        document.documentElement.classList.add('light');
        document.documentElement.classList.remove('dark');
        function applyBody() {
          const body = document.body;
          if (body) {
            body.classList.add('light');
            body.classList.remove('dark');
          } else {
            requestAnimationFrame(applyBody);
          }
        }
        applyBody();

        // Pull custom title / favicon if the operator configured them.
        // Custom CSS / JS injection is intentionally NOT loaded on the
        // login page — the login screen must remain a known-trusted
        // surface even if an admin's customCSS would otherwise reskin
        // it (avoids look-alike credential phishing).
        const apiBase = window.location.origin;
        fetch(`${apiBase}/api/navbar/config`)
          .then((res) => (res.ok ? res.json() : null))
          .then((config) => {
            if (!config) return;
            if (config.text) {
              document.title = `登录 · ${config.text}`;
            }
            if (config.logo) {
              const favicon = document.querySelector('link[rel="icon"]');
              if (favicon) {
                favicon.href = config.logo;
                const ext = config.logo.toLowerCase().split('.').pop().split('?')[0];
                if (ext === 'svg') favicon.type = 'image/svg+xml';
                else if (ext === 'png') favicon.type = 'image/png';
                else if (ext === 'jpg' || ext === 'jpeg') favicon.type = 'image/jpeg';
                else if (ext === 'ico') favicon.type = 'image/x-icon';
                else favicon.removeAttribute('type');
              }
            }
          })
          .catch(() => {});
      })();
    </script>
  </head>
  <body class="hotaru-theme light">
    <LoginForm />
  </body>
</html>
